    "Sign in" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Войти" } }, "tg" : { "stringUnit" : { "state" : "translated", "value" : "Ворид шудан" } } } },
    "Sign out" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Выйти" } }, "tg" : { "stringUnit" : { "state" : "translated", "value" : "Баромадан" } } } },
    "Sign out of Toj?" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Выйти из Toj?" } }, "tg" : { "stringUnit" : { "state" : "translated", "value" : "Аз Toj мебароед?" } } } },
    "Start a private conversation with someone you know." : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Начните приватный разговор с близким человеком." } }, "tg" : { "stringUnit" : { "state" : "translated", "value" : "Бо шахси шинос суҳбати махфӣ оғоз кунед." } } } },
    "This device" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Это устройство" } }, "tg" : { "stringUnit" : { "state" : "translated", "value" : "Ин дастгоҳ" } } } },
    "Try another name or message." : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Попробуйте другое имя или сообщение." } }, "tg" : { "stringUnit" : { "state" : "translated", "value" : "Ном ё паёми дигарро санҷед." } } } },
    "Verification code" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Код подтверждения" } }, "tg" : { "stringUnit" : { "state" : "translated", "value" : "Рамзи тасдиқ" } } } },
    "Verify deletion" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Подтвердите удаление" } }, "tg" : { "stringUnit" : { "state" : "translated", "value" : "Тасдиқи несткунӣ" } } } },
    "We sent a six-digit code to your phone." : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Мы отправили шестизначный код на ваш телефон." } }, "tg" : { "stringUnit" : { "state" : "translated", "value" : "Мо рамзи шашрақамаро ба телефони шумо фиристодем." } } } },
    "Welcome to Toj" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Добро пожаловать в Toj" } }, "tg" : { "stringUnit" : { "state" : "translated", "value" : "Хуш омадед ба Toj" } } } },
    "Your contacts will appear here in a future update." : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Контакты появятся здесь в одном из следующих обновлений." } }, "tg" : { "stringUnit" : { "state" : "translated", "value" : "Тамосҳои шумо дар навсозии оянда дар ин ҷо пайдо мешаванд." } } } },
    "Your conversations stay private" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Ваши разговоры остаются приватными" } }, "tg" : { "stringUnit" : { "state" : "translated", "value" : "Суҳбатҳои шумо махфӣ мемонанд" } } } },
    "Your identifying account data will be erased. Delivered messages remain in other participants’ chat history." : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Идентифицирующие данные аккаунта будут удалены. Доставленные сообщения останутся в истории других участников." } }, "tg" : { "stringUnit" : { "state" : "translated", "value" : "Маълумоти шиносоии ҳисоби шумо нест мешавад. Паёмҳои расонидашуда дар таърихи дигар иштирокчиён мемонанд." } } } },
    "Demo conversation" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Демонстрационный чат" } }, "tg" : { "stringUnit" : { "state" : "translated", "value" : "Чати намоишӣ" } } } },
    "Explore demo" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Открыть демо" } }, "tg" : { "stringUnit" : { "state" : "translated", "value" : "Дидани намуна" } } } },
    "No account or SMS required" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Без аккаунта и SMS" } }, "tg" : { "stringUnit" : { "state" : "translated", "value" : "Бе ҳисоб ва SMS" } } } },
    "This chat is local to demo mode." : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Этот чат существует только в деморежиме." } }, "tg" : { "stringUnit" : { "state" : "translated", "value" : "Ин чат танҳо дар ҳолати намоишӣ аст." } } } },
    "Your name" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Ваше имя" } }, "tg" : { "stringUnit" : { "state" : "translated", "value" : "Номи шумо" } } } },
    "Reply" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Ответить" } }, "tg" : { "stringUnit" : { "state" : "translated", "value" : "Ҷавоб додан" } } } },
    "React" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Реакция" } }, "tg" : { "stringUnit" : { "state" : "translated", "value" : "Вокуниш" } } } },
