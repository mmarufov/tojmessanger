    "Fast, private messaging made for your people." : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Быстрое и приватное общение для своих." } }, "tg" : { "stringUnit" : { "state" : "translated", "value" : "Паёмрасонии зуду махфӣ барои наздикони шумо." } } } },
