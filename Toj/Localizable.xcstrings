    "Enter the fresh six-digit code. This action cannot be undone." : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Введите новый шестизначный код. Это действие нельзя отменить." } }, "tg" : { "stringUnit" : { "state" : "translated", "value" : "Рамзи нави шашрақамаро ворид кунед. Ин амал баргардонида намешавад." } } } },
    "Enter the phone number of a Toj user." : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Введите номер телефона пользователя Toj." } }, "tg" : { "stringUnit" : { "state" : "translated", "value" : "Рақами телефони корбари Toj-ро ворид кунед." } } } },
