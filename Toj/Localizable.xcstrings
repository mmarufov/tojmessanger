    "Delete" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Удалить" } }, "tg" : { "stringUnit" : { "state" : "translated", "value" : "Нест кардан" } } } },
    "Delete message?" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Удалить сообщение?" } }, "tg" : { "stringUnit" : { "state" : "translated", "value" : "Паёмро нест мекунед?" } } } },
    "This removes the message for everyone in this conversation." : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Сообщение будет удалено у всех участников этого чата." } }, "tg" : { "stringUnit" : { "state" : "translated", "value" : "Ин паём барои ҳамаи иштирокчиёни ин суҳбат нест карда мешавад." } } } },
